<mapper namespace="localMapper">

    <!-- 글 등록 -->
    <insert id="create" parameterType="net.koreate.hellking.board.vo.LocalBoardVO">
        INSERT INTO local_board (bno, title, content, nickname, category_id, regdate, viewcnt, agree)
        VALUES (local_board_seq.NEXTVAL, #{title}, #{content}, #{nickname}, #{categoryId}, SYSDATE, 0, 0)
    </insert>

    <!-- 검색 + 페이징 -->
    <select id="listSearch" parameterType="net.koreate.hellking.board.util.LocalBoardSearchCriteria"
            resultType="net.koreate.hellking.board.vo.LocalBoardVO">
        SELECT *
        FROM local_board
        <where>
            <if test="searchType != null and keyword != null and keyword != ''">
                <choose>
                    <when test="searchType == 'title'">
                        title LIKE '%' || #{keyword} || '%'
                    </when>
                    <when test="searchType == 'nickname'">
                        nickname LIKE '%' || #{keyword} || '%'
                    </when>
                </choose>
            </if>
            <if test="categoryId != null and categoryId > 0">
                AND category_id = #{categoryId}
            </if>
        </where>
        ORDER BY bno DESC
        OFFSET #{startRow} ROWS FETCH NEXT #{perPageNum} ROWS ONLY
    </select>

    <!-- 검색된 총 개수 -->
    <select id="countSearch" parameterType="net.koreate.hellking.board.util.LocalBoardSearchCriteria" resultType="int">
        SELECT COUNT(*)
        FROM local_board
        <where>
            <if test="searchType != null and keyword != null and keyword != ''">
                <choose>
                    <when test="searchType == 'title'">
                        title LIKE '%' || #{keyword} || '%'
                    </when>
                    <when test="searchType == 'nickname'">
                        nickname LIKE '%' || #{keyword} || '%'
                    </when>
                </choose>
            </if>
            <if test="categoryId != null and categoryId > 0">
                AND category_id = #{categoryId}
            </if>
        </where>
    </select>

    <!-- 상세 조회 -->
